# Copy to scripts/smoke-sandbox.<env>.env (e.g. smoke-sandbox.dev.env) or
# scripts/smoke-dev-sandbox.env and fill in values. Env files are gitignored.
#
# Usage:
#   SMOKE_ENV=dev sh scripts/smoke-sandbox.sh
#   SMOKE_ENV_FILE=scripts/smoke-sandbox.stage.env sh scripts/smoke-sandbox.sh
#
# Optional:
#   SMOKE_EXTENDED=1          — also create/exec/delete a second sandbox (snapshot restore)
# --- dev example ---
# SANDBOX_API_BASE=https://sandbox-api.dev.example.com
# SANDBOX_API_KEY=your-api-key   # admin key (SANDBOX_API_KEYS); smoke mints a tenant key from it
#
# --- stage / prod with Kubernetes API key ---
# SANDBOX_API_BASE=https://sandbox-api.stage.example.com
# KUBE_NAMESPACE=n8n-sandbox
# KUBE_AUTH_SECRET=n8n-sandbox-api-auth
# KUBE_AUTH_SECRET_KEY=api-keys
#
# --- local (or use: make smoke) ---
# SANDBOX_API_BASE=http://localhost:8080
# SANDBOX_API_KEY=test
