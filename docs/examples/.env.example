# n8n Sandbox Service — environment variables
# Copy this file to .env and replace the placeholder values.

# --- API ---
SANDBOX_API_KEYS=changeme
SANDBOX_API_RUNNER_REGISTRATION_TOKEN=changeme
SANDBOX_API_RUNNER_API_KEY=changeme

# --- Runner ---
SANDBOX_RUNNER_API_KEYS=changeme
SANDBOX_RUNNER_REGISTRATION_TOKEN=changeme
