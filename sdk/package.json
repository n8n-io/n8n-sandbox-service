{
  "name": "@n8n/sandbox-client",
  "version": "1.0.0",
  "description": "TypeScript client for the n8n sandbox service API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:dev": "vitest",
    "fmt": "oxfmt src/ test/",
    "fmt:check": "oxfmt --check src/ test/",
    "lint": "oxlint src/ test/",
    "lint:fix": "oxlint --fix src/ test/"
  },
  "engines": {
    "node": ">=22.16",
    "pnpm": ">=10.22.0"
  },
  "dependencies": {
    "axios": "1.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsup": "^8.0.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.1"
  }
}
